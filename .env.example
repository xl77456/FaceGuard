# 複製此檔案為 .env 並填入真實數值
# cp .env.example .env

# ===== 系統安全與 API 通訊 =====
LOCAL_SECRET=replace_with_a_strong_random_secret
LOCAL_API=http://127.0.0.1:5001/action
BOT_LOCAL_API=http://127.0.0.1:5002/alert

# ===== Discord Bot 設定 =====
# 至 https://discord.com/developers/applications 申請 Bot Token
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# 可接受多個 ID，以逗號分隔（右鍵使用者 → 複製 ID）
ALLOWED_DISCORD_USER_IDS=your_discord_user_id_here
# 右鍵頻道 → 複製頻道 ID
ALERT_CHANNEL_ID=your_discord_channel_id_here

# ===== 路徑與資料庫 =====
DB_PATH=faceguard_events.db
IMG_FOLDER=alert_image
DATASET_DIR=dataset
NPZ_PATH=whitelistv2.npz
ONNX_PATH=models/modelrgb.onnx

# ===== 硬體控制 =====
# Windows: COM3, COM9 等；Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0 等
ARDUINO_PORT=COM9
BAUD_RATE=9600
